# Vault Env Manager Configuration
# This is a placeholder .env file.
APP_NAME=VaultEnvManager
STORAGE_ENCRYPTION_KEY=your-32-character-encryption-key-here
DEBUG=true

# Vault Default Configuration
VAULT_ORIGIN=https://vault.example.com
VAULT_UI_DOMAIN=vault.example.com
VAULT_NAMESPACE=
VAULT_DISCOVERY_PATH=EXAMPLE/
SCRAPING_URL=/v1/environment/
VERIFY_SSL=true
THEME_MODE=Dark
COLOR_THEME=sapphire
OS_STYLE=glass
UI_SCALE=1.0
